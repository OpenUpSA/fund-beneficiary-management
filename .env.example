# ---------------------------------------------------------------------------
# Server secrets (runtime — never exposed to the browser)
# ---------------------------------------------------------------------------
IMAGEKIT_PRIVATE_KEY=https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY=https://imagekit.io/dashboard/developer/api-keys
NEXTAUTH_SECRET=password_nextauth
NEXTAUTH_URL=http://localhost:3000
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5435/db"

# Email Configuration (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Secret used to authenticate scheduled/cron requests
CRON_SECRET=changeme

# ---------------------------------------------------------------------------
# Public config (NEXT_PUBLIC_* — baked into the build; set at build time)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/IMAGEKIT_ID"
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# LDA Terminology (optional - defaults shown)
NEXT_PUBLIC_LDA_SHORT_NAME=LDA
NEXT_PUBLIC_LDA_SHORT_NAME_PLURAL=LDAs
NEXT_PUBLIC_LDA_FULL_NAME=Local Development Agency
NEXT_PUBLIC_LDA_FULL_NAME_PLURAL=Local Development Agencies
# URL path for LDA pages (e.g., "beneficiaries" makes URLs like /dashboard/beneficiaries)
NEXT_PUBLIC_LDA_URL_PATH=ldas

# Branding (optional - defaults shown)
NEXT_PUBLIC_LOGO_PATH=/images/logo.webp
NEXT_PUBLIC_FAVICON_PATH=/images/favicon/favicon.ico
