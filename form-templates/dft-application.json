{
  "title": "DFT Application",
  "sections": [
    {
      "title": "Activity information",
      "fields": [
        {
          "name": "activity_name",
          "type": "text",
          "label": "Name of activity",
          "required": true,
          "placeholder": "Enter the name of the activity"
        },
        {
          "name": "activity_date",
          "type": "date",
          "label": "Date of activity",
          "required": true
        },
        {
          "name": "activity_type",
          "type": "select",
          "label": "Type of activity",
          "options": [
            {
              "label": "Campaigns",
              "value": "campaigns"
            },
            {
              "label": "Workshop",
              "value": "workshop"
            },
            {
              "label": "Organisational capacity building",
              "value": "organisational_capacity_building"
            },
            {
              "label": "Community meetings",
              "value": "community_meetings"
            }
          ],
          "required": true
        },
        {
          "name": "training_type",
          "type": "multiselect",
          "label": "Type of training to be given",
          "options": [],
          "required": true,
          "depends_on": {
            "field": "activity_type",
            "rules": [
              {
                "when": "campaigns",
                "label": "Type of campaigns to be given",
                "options": [
                  {
                    "label": "GBV prevention campaign",
                    "value": "gbv_prevention_campaign"
                  },
                  {
                    "label": "Youth Campaign",
                    "value": "youth_campaign"
                  },
                  {
                    "label": "Substance abuse campaign",
                    "value": "substance_abuse_campaign"
                  },
                  {
                    "label": "Service delivery campaign",
                    "value": "service_delivery_campaign"
                  },
                  {
                    "label": "Human rights campaign",
                    "value": "human_rights_campaign"
                  },
                  {
                    "label": "Other",
                    "value": "other"
                  }
                ]
              },
              {
                "when": "workshop",
                "label": "Type of workshop to be given",
                "options": [
                  {
                    "label": "Climate change workshop",
                    "value": "climate_change_workshop"
                  },
                  {
                    "label": "Gender related workshop",
                    "value": "gender_related_workshop"
                  },
                  {
                    "label": "Youth employment workshop",
                    "value": "youth_employment_workshop"
                  },
                  {
                    "label": "Youth development workshop",
                    "value": "youth_development_workshop"
                  },
                  {
                    "label": "IDP workshop",
                    "value": "idp_workshop"
                  },
                  {
                    "label": "Human rights workshop",
                    "value": "human_rights_workshop"
                  },
                  {
                    "label": "Food garden workshop",
                    "value": "food_garden_workshop"
                  },
                  {
                    "label": "Permaculture workshop",
                    "value": "permaculture_workshop"
                  },
                  {
                    "label": "Other",
                    "value": "other"
                  }
                ]
              },
              {
                "when": "organisational_capacity_building",
                "label": "Type of Organisational capacity building to be given",
                "options": [
                  {
                    "label": "Staff training",
                    "value": "staff_training"
                  },
                  {
                    "label": "Board member training",
                    "value": "board_member_training"
                  },
                  {
                    "label": "Volunteer training",
                    "value": "volunteer_training"
                  },
                  {
                    "label": "Other",
                    "value": "other"
                  }
                ]
              },
              {
                "when": "community_meetings",
                "label": "Type of community meeting to be given",
                "options": [
                  {
                    "label": "Service delivery",
                    "value": "service_delivery"
                  },
                  {
                    "label": "Annual General meeting",
                    "value": "annual_general_meeting"
                  },
                  {
                    "label": "Community safety meetings",
                    "value": "community_safety_meetings"
                  },
                  {
                    "label": "Other",
                    "value": "other"
                  }
                ]
              }
            ],
            "enabled_when": [
              "campaigns",
              "workshop",
              "organisational_capacity_building",
              "community_meetings"
            ],
            "default_disabled": true
          }
        },
        {
          "name": "focus_areas",
          "type": "multiselect",
          "label": "Which of your focus areas does this activity relate to?",
          "config": { "dynamicOptionTable": "focus_areas" },
          "required": true
        },
        {
          "name": "expected_participants",
          "type": "number",
          "label": "Expected number of participants",
          "required": true,
          "placeholder": "Enter the expected number of participants"
        },
        {
          "name": "why_activity_needed",
          "type": "textarea",
          "label": "Why is the activity needed?",
          "required": true,
          "description": "Describe the need or opportunity sparked the organising of this event",
          "placeholder": "Enter details here"
        },
        {
          "name": "who_will_facilitate",
          "type": "textarea",
          "label": "Who will facilitate this activity?",
          "required": true,
          "description": "Provide the names of any individuals or organisations that assisted with this activity",
          "placeholder": "Enter details here"
        },
        {
          "name": "activity_venue",
          "type": "textarea",
          "label": "Where will the activity be held?",
          "required": true,
          "description": "What venue will you be using and where is that venue situated?",
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "Proposed budget",
      "fields": [
        {
          "name": "planned_total_cost",
          "type": "currency",
          "label": "Planned total cost to deliver the training",
          "required": true,
          "placeholder": "0.00"
        },
        {
          "name": "funding_amount_requested",
          "type": "currency",
          "label": "Funding amount being requested from SCAT",
          "required": true,
          "placeholder": "0.00"
        },
        {
          "name": "budget_notice",
          "type": "info",
          "label": "",
          "notice": "<strong>Please use our budget template.</strong> To ensure you are reporting correctly, please use the template created by SCAT. <a href='/templates/budget.pdf'>Download budget (.pdf)</a> or <a href='/templates/budget.xls'>Download budget (.xls)</a>."
        },
        {
          "name": "budget_upload",
          "type": "fileUpload",
          "label": "Upload a copy of your budget",
          "multiple": false,
          "required": true,
          "config": {
            "destination": "document",
            "accepted_file_types": ["application/pdf", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "application/vnd.ms-excel", "image/png", "image/jpeg", "image/jpg"]
          }
        }
      ]
    },
    {
      "title": "Board approval",
      "description": "In order to receive funding for this activity, we require signed approval from at least two board members.",
      "fields": [
        {
          "name": "board_approval_notice",
          "type": "info",
          "label": "",
          "notice": "<strong>Download a board approval form.</strong> <a href='/templates/board-approval-form.pdf'>Download form</a>."
        },
        {
          "name": "board_approval_form",
          "type": "fileUpload",
          "label": "Upload a signed board approval form",
          "required": true,
          "config": {
            "destination": "media",
            "accepted_file_types": ["image/png", "image/jpeg", "image/jpg", "application/pdf"]
          }
        }
      ]
    }
  ]
}