{
  "title": "Field Reporting Form",
  "sections": [
    {
      "title": "Details of site visit",
      "fields": [
        {
          "name": "funders",
          "type": "multiselect",
          "label": "Funders",
          "config": {
            "dynamicOptionTable": "funders"
          },
          "required": true,
          "placeholder": "Select funders"
        },
        {
          "name": "venue",
          "type": "text",
          "label": "Venue",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "date_of_visit",
          "type": "date",
          "label": "Date of visit",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "met_staff_representatives",
          "type": "radio",
          "label": "Did you meet with any staff representatives?",
          "options": [
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "Yes",
              "value": "yes"
            }
          ],
          "required": true
        },
        {
          "name": "staff_representatives_met",
          "type": "multiselect",
          "label": "Staff representatives met",
          "config": {
            "dynamicOptionTable": "staff_members"
          },
          "required": true,
          "placeholder": "Select staff representatives met",
          "show_if": {
            "field": "met_staff_representatives",
            "value": "yes"
          }
        },
        {
          "name": "met_committee_representatives",
          "type": "radio",
          "label": "Did you meet with any committee representatives?",
          "options": [
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "Yes",
              "value": "yes"
            }
          ],
          "required": true
        },
        {
          "name": "committee_representatives_met",
          "type": "multiselect",
          "label": "Committee representatives met",
          "config": {
            "dynamicOptionTable": "committee_members"
          },
          "required": true,
          "placeholder": "Select committee representatives met",
          "show_if": {
            "field": "met_committee_representatives",
            "value": "yes"
          }
        }
      ]
    },
    {
      "title": "Visit context",
      "fields": [
        {
          "name": "org_profile_changed",
          "type": "radio",
          "label": "Has the organisational profile changed recently?",
          "options": [
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "Yes",
              "value": "yes"
            }
          ],
          "required": true
        },
        {
          "name": "updated_org_profile",
          "type": "textarea",
          "label": "Updated organisational profile",
          "required": true,
          "placeholder": "Enter details here",
          "show_if": {
            "field": "org_profile_changed",
            "value": "yes"
          }
        },
        {
          "name": "visit_objectives",
          "type": "textarea",
          "label": "Objectives of the visit",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "programme_activities",
          "type": "textarea",
          "label": "Programme activities and highlights",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "community_profile",
          "type": "textarea",
          "label": "Community profile",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
