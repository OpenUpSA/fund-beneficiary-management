    {
      "title": "Organisational performance",
      "fields": [
        {
          "name": "planning_monitoring",
          "type": "textarea",
          "label": "Planning, monitoring, implementation of plans and evaluation of the organisations work",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "committee_performance",
          "type": "textarea",
          "label": "Performance of the committee in terms of overall governance and staff management",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "staff_performance",
          "type": "textarea",
          "label": "Performance of the staff in terms of the implementation of plans",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "staff_committee_relations",
          "type": "textarea",
          "label": "Staff and committee working relations",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "fundraising_local",
          "type": "textarea",
          "label": "Fundraising events in the local community (including FRIS)",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "fundraising_external",
          "type": "textarea",
          "label": "Fundraising events outside the community",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "scat_dft_funds",
          "type": "textarea",
          "label": "Organisations use of SCAT DFT funds",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "agm_details",
          "type": "textarea",
          "label": "AGM details",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "Financial management",
      "fields": [
        {
          "name": "analysis_book",
          "type": "textarea",
          "label": "Analysis book (month last updated)",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "bank_reconciliations",
          "type": "textarea",
          "label": "Bank reconciliations (month last updated)",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "petty_cash_book",
          "type": "textarea",
          "label": "Petty cash book (month last updated)",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "last_financial_report",
          "type": "textarea",
          "label": "Last financial report to SCAT and the quality of the report",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "budgets_expenditure",
          "type": "textarea",
          "label": "Budgets and actual expenditure",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "annual_audit",
          "type": "textarea",
          "label": "Annual audit and implementation of the auditor's recommendations",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "General administration",
      "fields": [
        {
          "name": "filing_system",
          "type": "textarea",
          "label": "Filing system",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "record_keeping",
          "type": "textarea",
          "label": "Record keeping",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "correspondence_record",
          "type": "textarea",
          "label": "Correspondence record",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "staff_attendance",
          "type": "textarea",
          "label": "Staff's work attendance",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "last_activity_report",
          "type": "textarea",
          "label": "Last activity report to SCAT and the quality of the report",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "Other commentary",
      "fields": [
        {
          "name": "program_implementation",
          "type": "textarea",
          "label": "Comment on program specific implementation",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "key_challenges",
          "type": "textarea",
          "label": "Key challenges, remedies and lessons learnt",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "other_notes",
          "type": "textarea",
          "label": "Other/further notes and comments",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "Outcomes",
      "fields": [
        {
          "name": "key_outputs",
          "type": "textarea",
          "label": "Key outputs/results from the visit",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "implementation_details",
          "type": "textarea",
          "label": "Details of the implementation of the activities implemented at the site",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "areas_of_improvement",
          "type": "textarea",
          "label": "Areas of improvement for the organisation",
          "required": true,
          "placeholder": "Enter details here"
        }
      ]
    },
    {
      "title": "Next steps",
      "fields": [
        {
          "name": "way_forward",
          "type": "textarea",
          "label": "Way forward",
          "required": true,
          "placeholder": "Enter details here"
        },
        {
          "name": "next_visit_date",
          "type": "date",
          "label": "Date for next visit",
          "required": true
        }
      ]
    },
    {
      "title": "Evidence",
      "fields": [
        {
          "name": "attendance_register",
          "type": "fileUpload",
          "label": "Upload attendance register",
          "multiple": true,
          "required": false,
          "config": {
            "destination": "document",
            "accepted_file_types": ["image/png", "image/jpeg", "image/jpg", "application/pdf"]
          }
        },
        {
          "name": "visit_photos",
          "type": "fileUpload",
          "label": "Upload photos from visit",
          "multiple": true,
          "required": true,
          "accepted_file_types": [
            "image/*"
          ]
        }
      ]
    }
  ]
}