    {
      "title": "Evidence",
      "fields": [
        {
          "name": "attendance_register",
          "type": "fileUpload",
          "label": "Upload attendance register",
          "multiple": true,
          "required": false,
          "config": {
            "destination": "document",
            "accepted_file_types": ["image/png", "image/jpeg", "image/jpg", "application/pdf"]
          }
        },
        {
          "name": "visit_photos",
          "type": "fileUpload",
          "label": "Upload photos from visit",
          "multiple": true,
          "required": true,
          "accepted_file_types": [
            "image/*"
          ]
        }
      ]
